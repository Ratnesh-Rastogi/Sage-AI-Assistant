# Copy this file to .env and fill in real values. Never commit .env.

# --- Application ---
APP_ENV=development
APP_DEBUG=true

# --- Database ---
POSTGRES_USER=sage_user
POSTGRES_PASSWORD=your_database_password
POSTGRES_DB=sage_db
DATABASE_URL=postgresql+asyncpg://sage_user:your_database_password@postgres:5432/sage_db
DATABASE_ECHO=false

# --- AI Providers (used starting Phase 2) ---
DEFAULT_AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
CLAUDE_API_KEY=your_claude_key
OPENROUTER_API_KEY=your_openrouter_key

# --- Search Provider (used starting Phase 5) ---
TAVILY_API_KEY=your_tavily_key

# --- Storage ---
STORAGE_PATH=/app/storage/files
MAX_UPLOAD_SIZE_MB=25

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Security ---
SECRET_KEY=change_this_to_a_random_secret

# --- CORS ---
CORS_ORIGINS=http://localhost:5173
